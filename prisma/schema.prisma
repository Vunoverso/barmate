generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  status        String       @default("active")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
}

model Organization {
  id           String             @id @default(cuid())
  legalName    String
  tradeName    String
  document     String?
  slug         String             @unique
  status       String             @default("TRIAL")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  memberships  Membership[]
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           String         @default("OWNER")
  status         String         @default("active")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

// ---------- Dados Operacionais (Postgres/Vultr) ----------

/// Armazena todos os estados operacionais como JSON (produtos, vendas, etc.)
model AppState {
  id             String   @id @default(cuid())
  key            String
  organizationId String
  value          Json
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("app_state")
}

/// Comandas abertas com suporte a soft-delete
model OpenOrder {
  id             String    @id
  organizationId String
  data           Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("open_orders")
}

/// Pedidos de convidados via QR code
model GuestRequest {
  id                String    @id @default(cuid())
  organizationId    String
  associatedOrderId String?
  data              Json
  requestedAt       DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([organizationId])
  @@map("guest_requests")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  refresh_token_expires_in Int?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}