
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Legado operacional
    match /open_orders/{orderId} {
      allow read, write: if true;
    }
    match /guest_requests/{requestId} {
      allow read, write: if true;
    }
    match /products/{id} {
      allow read, write: if true;
    }
    match /clients/{id} {
      allow read, write: if true;
    }
    match /product_categories/{id} {
      allow read, write: if true;
    }
    match /settings_v2/{id} {
      allow read, write: if true;
    }
    match /settings/{id} {
      allow read, write: if true;
    }

    // Multi-tenancy: dados operacionais por organização
    match /organizations/{orgId} {
      allow read, write: if true;
    }
    match /organizations/{orgId}/{collection}/{docId} {
      allow read, write: if true;
    }

    // Admin SaaS: tickets, cancelamentos e configurações globais
    match /tickets/{ticketId} {
      allow read, write: if true;
    }
    match /cancellations/{id} {
      allow read, write: if true;
    }
    match /adminConfig/{id} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

