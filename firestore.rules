
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /open_orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }
    match /guest_requests/{requestId} {
      allow read: if true;
      allow write: if true;
    }
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
