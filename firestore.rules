
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /open_orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }
    match /guest_requests/{requestId} {
      allow read: if true;
      allow write: if true;
    }
    match /products/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /clients/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /product_categories/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /settings_v2/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
